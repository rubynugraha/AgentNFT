# ==========================================
# AI AGENT NFT - ENVIRONMENT CONFIGURATION
# ==========================================
# Copy this file to .env.local and fill in all required values

# ==========================================
# DATABASE CONFIGURATION (Neon PostgreSQL)
# ==========================================
# Get your connection string from: https://console.neon.tech/
# Format: postgresql://user:password@host/database?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.neon.tech/nftdb?sslmode=require

# ==========================================
# BLOCKCHAIN CONFIGURATION (Base Mainnet)
# ==========================================
# Smart Contract Address - Update this with your deployed contract
NEXT_PUBLIC_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Admin Wallet Address - For whitelist approval
NEXT_PUBLIC_ADMIN_ADDRESS=0x0000000000000000000000000000000000000000

# ==========================================
# PINATA IPFS CONFIGURATION (Required)
# ==========================================
# Get API keys from: https://app.pinata.cloud/keys
# These are REQUIRED for uploading NFT metadata to IPFS
PINATA_API_KEY=your_pinata_api_key_here
PINATA_API_SECRET=your_pinata_api_secret_here
